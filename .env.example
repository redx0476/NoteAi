# ── Core ─────────────────────────────────────────────────────────────────────
PORT=3000
JWT_SECRET=change-me-to-a-long-random-string

# Local Postgres connection string.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/noteai

# ── Real-time speech-to-text (Deepgram) — enables live WebSocket transcription ─
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3
DEEPGRAM_LANGUAGE=en

# ── LLM (OpenRouter) — summaries, action items, Q&A ──────────────────────────
OPENROUTER_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_API_KEY=
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# ── Batch speech-to-text (Whisper-compatible) — used when Deepgram is off ─────
STT_API_URL=https://api.openai.com/v1/audio/transcriptions
STT_API_KEY=
STT_MODEL=whisper-1
STT_LANGUAGE=
# Speech-to-text batch fallback (used only when DEEPGRAM_API_KEY is empty)
STT_API_URL=https://api.groq.com/openai/v1/audio/transcriptions
STT_MODEL=whisper-large-v3-turbo

# ── Notetaker bot (Playwright) — joins Meet/Teams and records for you ─────────
# Run `npx playwright install --with-deps chromium` once before using the bot.
BOT_NAME=NoteAI Notetaker
BOT_HEADFUL=0                 # 1 = headful under Xvfb (fallback if headless audio is silent)
BOT_MAX_MINUTES=120           # hard cap per meeting
BOT_ADMISSION_TIMEOUT_MIN=10  # give up if not admitted from the lobby
BOT_MAX_CONCURRENT=3          # max simultaneous bot Chromiums (~400 MB each)
BOT_NO_SANDBOX=0              # 1 only inside Docker
# Public base URL of this app (bot WebSocket/API target + OAuth redirect base).
APP_URL=http://localhost:3000

# ── Google Calendar auto-join (OtterPilot-style autopilot) ────────────────────
# OAuth app redirect URI: ${APP_URL}/api/integrations/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── S3-compatible audio storage — unset S3_BUCKET → local data/audio/ ─────────
S3_ENDPOINT=                  # e.g. http://localhost:9000 for MinIO; empty for AWS S3
S3_REGION=us-east-1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=1         # required for MinIO; 0 for AWS virtual-hosted style
S3_PROXY=0                    # 1 = stream audio through the server (private MinIO)
