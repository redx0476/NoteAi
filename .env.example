# ── Core ─────────────────────────────────────────────────────────────────────
PORT=3000
JWT_SECRET=change-me-to-a-long-random-string

# Local Postgres connection string.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/noteai

# ── Real-time speech-to-text (Deepgram) — enables live WebSocket transcription ─
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3
DEEPGRAM_LANGUAGE=multi

# ── LLM (OpenRouter) — summaries, action items, Q&A ──────────────────────────
OPENROUTER_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-120b:free

# ── Batch speech-to-text (Whisper-compatible) — used when Deepgram is off ─────
STT_API_URL=https://api.openai.com/v1/audio/transcriptions
STT_API_KEY=
STT_MODEL=whisper-1
STT_LANGUAGE=
