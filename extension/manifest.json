{
  "manifest_version": 3,
  "name": "NOTEAI — AI Meeting Notes",
  "version": "1.0.0",
  "description": "Live transcription & AI notes for Google Meet and Microsoft Teams.",
  "permissions": ["tabCapture", "offscreen", "storage", "activeTab", "scripting", "tabs"],
  "host_permissions": [
    "https://meet.google.com/*",
    "https://teams.microsoft.com/*",
    "https://teams.live.com/*",
    "http://localhost:3000/*"
  ],
  "background": { "service_worker": "background.js", "type": "module" },
  "action": { "default_popup": "popup/index.html", "default_title": "NOTEAI" },
  "icons": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" },
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["config.js", "content/meet.js", "content/panel.js"],
      "css": ["content/panel.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://teams.microsoft.com/*", "https://teams.live.com/*"],
      "js": ["config.js", "content/teams.js", "content/panel.js"],
      "css": ["content/panel.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["http://localhost:3000/*"],
      "js": ["content/sync-auth.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    { "resources": ["content/panel.css"], "matches": ["<all_urls>"] }
  ]
}
